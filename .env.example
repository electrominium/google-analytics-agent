# Google OAuth2 — create a Desktop app OAuth client in Google Cloud Console
# APIs & Services → Credentials → Create → OAuth 2.0 Client ID → Desktop app
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
# Filled in automatically by: npm run setup-auth
GOOGLE_OAUTH_REFRESH_TOKEN=

# HitCalc — Google Search Console
# Exact URL as it appears in GSC (include trailing slash)
HITCALC_GSC_SITE_URL=https://hitcalc.com/

# HitCalc — Google Analytics 4
# Admin → Property Settings → Property ID (numbers only)
HITCALC_GA4_PROPERTY_ID=123456789

# SacredCal — Google Search Console
SACREDCAL_GSC_SITE_URL=https://sacredcal.com/

# SacredCal — Google Analytics 4
SACREDCAL_GA4_PROPERTY_ID=987654321

# Resend — get from resend.com dashboard (same key used in your apps)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Who receives the daily report
REPORT_TO_EMAIL=electromlabs@gmail.com
